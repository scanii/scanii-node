{
  "name": "@scanii/core",
  "version": "1.0.0",
  "description": "Zero-dependency TypeScript SDK for the Scanii content security API",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/scanii/scanii-node.git"
  },
  "homepage": "https://scanii.com",
  "bugs": {
    "url": "https://github.com/scanii/scanii-node/issues"
  },
  "keywords": [
    "scanii",
    "antivirus",
    "malware",
    "content-security",
    "nsfw",
    "dlp"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
